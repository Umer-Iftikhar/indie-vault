@model IEnumerable<IndieVault.Models.Game>

@{
    ViewData["Title"] = "My Games";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
        <a asp-controller="Game" asp-action="Upload" class="btn btn-primary">+ Upload New Game</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert No-game">
            <h4>No games found!</h4>
            <p>Ready to share your creation with the world?</p>
            <a asp-controller="Game" asp-action="Upload" class="btn btn-lg btn-outline-primary">Start Uploading</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Cover</th>
                        <th>Title</th>
                        <th>Genre</th>
                        <th>Engine</th>
                        <th>Price</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var game in Model)
                    {
                        <tr>
                            <td>
                                <img src="@game.CoverImagePath" alt="Cover" style="width: 60px; height: 80px; object-fit: cover;" class="rounded shadow-sm" />
                            </td>
                            <td class="fw-bold">@game.Title</td>
                            <td>@game.Genre?.Name</td>
                            <td>@game.Engine?.Name</td>
                            <td>@(game.Price == 0 ? "Free" : $"${game.Price}")</td>
                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-controller="Game" asp-action="Edit" asp-route-id="@game.Id" class="btn btn-sm btn-outline-warning">Edit</a>

                                    @* Delete Mini-Form *@
                                    <form asp-controller="Game" asp-action="Delete" asp-route-id="@game.Id" method="post"
                                          onsubmit="return confirm('Are you sure you want to delete this game?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>