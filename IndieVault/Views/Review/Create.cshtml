@model IndieVault.ViewModels.ReviewViewModel

@{
    ViewData["Title"] = "Write a Review";
}

<style>
    .star-rating 
    {
        display: flex;
        flex-direction: row-reverse;
        justify-content: flex-end;
    }

        .star-rating input 
        {
            display: none;
        }

        .star-rating label 
        {
            font-size: 2.5rem;
            color: #ddd;
            cursor: pointer;
            transition: color 0.15s ease-in-out;
            padding: 0 0.2rem;
        }

            .star-rating label:hover,
            .star-rating label:hover ~ label,
            .star-rating input:checked ~ label 
            {
                color: #ffc107;
            }
</style>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            @* Using TempData to show the error if the controller redirects back *@
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
            }

            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h2 class="card-title mb-4 text-center">@ViewData["Title"]</h2>

                    <form asp-action="Create" method="post">
                        <input type="hidden" asp-for="GameId" />
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-4">
                            <label class="form-label d-block text-center">How would you rate your experience?</label>
                            <div class="star-rating">
                                @for (int i = 5; i >= 1; i--)
                                {
                                    <input type="radio" id="star-@i" asp-for="Rating" value="@i" />
                                    <label for="star-@i" title="@i stars">
                                        <i class="bi bi-star-fill"></i>
                                    </label>
                                }
                            </div>
                            <div class="text-center">
                                <span asp-validation-for="Rating" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Comment" class="form-label">Tell us more (Optional)</label>
                            <textarea asp-for="Comment" class="form-control" rows="4" placeholder="What stood out to you?"></textarea>
                            <span asp-validation-for="Comment" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">Post Review</button>
                            <a asp-controller="Game" asp-action="Details" asp-route-id="@Model.GameId" class="btn btn-link text-muted">Go Back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts 
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}